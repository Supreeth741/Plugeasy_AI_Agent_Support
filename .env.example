# ===========================================
# Plugeasy AI Agent Support - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# API KEY SETUP GUIDE:
#
# 1. TWILIO (call handling)
#    - Sign up at https://www.twilio.com/try-twilio
#    - Dashboard → copy Account SID and Auth Token
#    - Buy a phone number with Voice capability
#    - Configure the phone number webhook:
#      Voice "A Call Comes In" → https://{your-ngrok-url}/twilio/voice (HTTP POST)
#
# 2. OPENAI (Whisper STT + GPT-4)
#    - Sign up at https://platform.openai.com/signup
#    - API Keys → Create new secret key
#    - Add billing at Settings → Billing (need $5+ for GPT-4 access)
#
# 3. GOOGLE CLOUD TTS (text-to-speech)
#    - Create project at https://console.cloud.google.com
#    - Enable "Cloud Text-to-Speech API"
#    - IAM → Service Accounts → Create → Download JSON key
#    - Save as google-credentials.json in project root
# ===========================================

# Server
PORT=3000
NODE_ENV=development
BASE_URL=https://your-ngrok-url.ngrok-free.app

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# OpenAI (used for both Whisper STT and GPT-4)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Cloud TTS
GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json

# Call Settings
MAX_RECORDING_SECONDS=30
MAX_CONVERSATION_TURNS=10
ESCALATION_PHONE_NUMBER=+91XXXXXXXXXX
