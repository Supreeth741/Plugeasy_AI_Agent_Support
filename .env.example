# ===========================================
# Plugeasy AI Agent Support - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# API KEY SETUP GUIDE:
#
# 1. TWILIO (call handling + speech recognition + voice)
#    - Sign up at https://www.twilio.com/try-twilio
#    - Dashboard -> copy Account SID and Auth Token
#    - Buy a phone number with Voice capability
#    - Configure the phone number webhook:
#      Voice "A Call Comes In" -> https://{your-ngrok-url}/twilio/voice (HTTP POST)
#
# 2. GOOGLE GEMINI (AI brain)
#    - Sign up at https://aistudio.google.com/
#    - Get an API key from Google AI Studio
# ===========================================

# Server
PORT=3000
NODE_ENV=development
BASE_URL=https://your-ngrok-url.ngrok-free.app

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# Google Gemini (AI brain)
GEMINI_API_KEY=your_gemini_api_key_here

# Call Settings
MAX_CONVERSATION_TURNS=10
ESCALATION_PHONE_NUMBER=+91XXXXXXXXXX
